// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum LearningObjective {
  CASUAL
  PROFESSIONAL
  TRAVEL
  EXAM
  FAMILY_AND_FRIENDS
  PRACTICE
}

enum Role {
  USER
  ADMIN
}

enum ClassRole {
  STUDENT
  MODERATOR
}

enum ActivityType {
  MULTI_CHOICE
  IMAGE_CHOICE
  STORY
  RADIO
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ActivityProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum AssetType {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

model User {
  id                String            @id @default(uuid(7))
  email             String            @unique
  targetLanguageId  Int?
  targetLanguage    TargetLanguage?   @relation(fields: [targetLanguageId], references: [id])
  password          String
  bio               String?           @db.VarChar(160)
  avatarUrl         String?
  username          String            @unique
  displayName       String?
  phone             String?           @unique
  learningObjective LearningObjective @default(CASUAL)
  nativeLanguage    String?
  dailyXpGoal       Int?
  role              Role              @default(USER)

  memberships  Membership[]
  ratingsGiven Rating[]     @relation("RatingGiver")
  ratingsRecd  Rating[]     @relation("RatingReceiver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats            Chat[]
  activityProgress UserActivityProgress[]
}

model UserActivityProgress {
  id String @id @default(uuid(7))

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  status ActivityProgressStatus @default(IN_PROGRESS)
  score  Float?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, activityId])
}

model Lesson {
  id    String @id @default(uuid(7))
  title String
  order Int

  lessonClassId String @default("7d98c187-ba47-49fe-9ec0-dca9189f3b90")
  lessonClass   Class  @relation(fields: [lessonClassId], references: [id])

  activities Activity[]
}

model Activity {
  id    String @id @default(uuid(7))
  title String

  lessonId String
  type     ActivityType

  order Int

  xpReward   Int         @default(10)
  difficulty Difficulty?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id])

  multiChoice MultiChoiceActivity?
  story       StoryActivity?
  radio       RadioChoiceActivity?

  activityProgress UserActivityProgress[]
}

model Asset {
  id          String    @id @default(uuid(7))
  type        AssetType
  name        String
  alt         String?
  description String?

  key String @unique

  mimeType String?
  size     Int?

  width  Int?
  height Int?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  storyPages            StoryPage[]
  multipleChoiceOptions MultipleChoiceOption[]
}

model MultiChoiceActivity {
  id String @id @default(uuid(7))

  activityId String @unique

  prompt      String
  explanation String?

  shuffle Boolean @default(true)

  activity Activity @relation(fields: [activityId], references: [id])

  options MultipleChoiceOption[]
  hints   Hint[]
}

model MultipleChoiceOption {
  id Int @id @default(autoincrement())

  activityId String

  text String?

  asset Asset?  @relation(fields: [assetId], references: [id])
  alt   String?

  isCorrect Boolean @default(false)

  position Int?

  activity MultiChoiceActivity @relation(fields: [activityId], references: [id])
  assetId  String?
}

model StoryActivity {
  id String @id @default(uuid())

  activityId String @unique

  title String

  activity Activity @relation(fields: [activityId], references: [id])

  pages StoryPage[]
}

model StoryPage {
  id String @id @default(cuid())

  storyId String

  content String
  asset   Asset  @relation(fields: [assetId], references: [id])

  order Int

  story   StoryActivity @relation(fields: [storyId], references: [id])
  assetId String
}

model RadioChoiceActivity {
  id String @id @default(cuid())

  activityId String @unique

  audioUrl   String
  transcript String?

  activity Activity @relation(fields: [activityId], references: [id])
}

model Hint {
  id         String   @id @default(uuid())
  activityId String
  text       String
  order      Int?
  createdAt  DateTime @default(now())

  activity MultiChoiceActivity @relation(fields: [activityId], references: [id])
}

model TargetLanguage {
  id                 Int     @id @default(autoincrement())
  name               String  @unique
  identityExpression String  @default("")
  users              User[]
  forums             Forum[]
}

model Membership {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  classId String
  class   Class  @relation(fields: [classId], references: [id])

  role ClassRole @default(STUDENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, classId])
}

model Forum {
  id         String         @id @default(uuid())
  name       String         @unique
  languageId Int
  language   TargetLanguage @relation(fields: [languageId], references: [id])
  classes    Class[]
}

model Chat {
  id       String @id @default(uuid())
  content  String
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  classId  String
  class    Class  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  ratings   Rating[]
}

model Rating {
  id String @id @default(uuid())

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id])

  giverId String
  giver   User   @relation("RatingGiver", fields: [giverId], references: [id])

  receiverId String
  receiver   User   @relation("RatingReceiver", fields: [receiverId], references: [id])

  pointValue Int @default(1)

  createdAt DateTime @default(now())
}

model Class {
  id          String       @id @default(uuid())
  level       Int
  name        String
  minPoints   Int
  forumId     String
  forum       Forum        @relation(fields: [forumId], references: [id])
  memberships Membership[]
  lessons     Lesson[]
  chats       Chat[]
}
