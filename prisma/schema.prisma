// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum LearningObjective {
  CASUAL
  PROFESSIONAL
  TRAVEL
  EXAM
  FAMILY_AND_FRIENDS
  PRACTICE
}

enum Role {
  USER
  ADMIN
}

enum ClassRole {
  STUDENT
  MODERATOR
}

enum ActivityType {
  MULTI_CHOICE
  IMAGE_CHOICE
  STORY
  RADIO
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ActivityProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum AssetType {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  UNKNOWN
}

model User {
  id                String            @id @default(uuid(7))
  email             String            @unique
  targetLanguageId  Int?
  targetLanguage    TargetLanguage?   @relation(fields: [targetLanguageId], references: [id])
  password          String
  bio               String?           @db.VarChar(160)
  avatarUrl         String?
  username          String            @unique
  displayName       String?
  phone             String?           @unique
  learningObjective LearningObjective @default(CASUAL)
  nativeLanguage    String?
  dailyXpGoal       Int?
  role              Role              @default(USER)

  memberships  Membership[]
  ratingsGiven Rating[]     @relation("RatingGiver")
  ratingsRecd  Rating[]     @relation("RatingReceiver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats            Chat[]
  activityProgress UserActivityProgress[]
  responses        Response[]
}

model UserActivityProgress {
  id String @id @default(uuid(7))

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  status ActivityProgressStatus @default(IN_PROGRESS)
  score  Float?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, activityId])
}

model Lesson {
  id    String @id @default(uuid(7))
  title String

  classAssignments ClassLessonAssignment[]
  activities       Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id String @id @default(uuid(7))

  title    String
  lessonId String
  type     ActivityType
  order    Int
  
  xpReward Int @default(10)
  difficulty Difficulty?

  lesson Lesson @relation(fields: [lessonId], references: [id])

  multiChoice MultiChoiceActivity?
  story       StoryActivity?
  radio       RadioChoiceActivity?

  activityProgress UserActivityProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id          String    @id @default(uuid(7))
  type        AssetType
  name        String    @unique
  alt         String?
  description String?

  key String @unique

  mimeType String?
  size     Int?

  width  Int?
  height Int?

  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  multipleChoiceOptions        MultipleChoiceOption[]
  multiChoiceActivityQuestions MultiChoiceActivityQuestion[]
}

model MultiChoiceActivity {
  id      String  @id @default(uuid(7))
  shuffle Boolean @default(true)

  activityId String   @unique
  activity   Activity @relation(fields: [activityId], references: [id])

  questions MultiChoiceActivityQuestion[]
}

model MultiChoiceActivityQuestion {
  id          String  @id @default(uuid(7))
  prompt      String
  explanation String?

  options MultipleChoiceOption[]
  hints   Hint[]

  assetName String?
  asset   Asset?  @relation(fields: [assetName], references: [name])

  points Int @default(1)

  multiChoiceActivityId String
  multiChoiceActivity   MultiChoiceActivity @relation(fields: [multiChoiceActivityId], references: [id])
}

model MultipleChoiceOption {
  id Int @id @default(autoincrement())

  questionId String

  text    String?
  assetName String?

  alt String?

  isCorrect Boolean @default(false)

  position Int?

  question MultiChoiceActivityQuestion @relation(fields: [questionId], references: [id])
  asset    Asset?                      @relation(fields: [assetName], references: [name])
}

model StoryActivity {
  id String @id @default(uuid())

  activityId String @unique
  title      String

  activity Activity    @relation(fields: [activityId], references: [id])
  pages    StoryPage[]
}

model StoryPage {
  id String @id @default(cuid())

  storyId String
  assetName String?
  content String
  order Int

  story StoryActivity @relation(fields: [storyId], references: [id])
}

model RadioChoiceActivity {
  id String @id @default(cuid())

  activityId String @unique

  audioUrl   String
  transcript String?

  activity Activity @relation(fields: [activityId], references: [id])
}

model Hint {
  id         String   @id @default(uuid())
  questionId String
  text       String
  order      Int?
  createdAt  DateTime @default(now())

  question MultiChoiceActivityQuestion @relation(fields: [questionId], references: [id])
}

model TargetLanguage {
  id                 Int     @id @default(autoincrement())
  name               String  @unique
  identityExpression String  @default("")
  users              User[]
  forums             Forum[]
}

model Membership {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  classId String
  class   Class  @relation(fields: [classId], references: [id])

  role ClassRole @default(STUDENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, classId])
}

model Forum {
  id         String         @id @default(uuid())
  name       String         @unique
  languageId Int
  language   TargetLanguage @relation(fields: [languageId], references: [id])
  classes    Class[]
}

model Chat {
  id       String @id @default(uuid())
  content  String
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  classId  String
  class    Class  @relation(fields: [classId], references: [id])

  createdAt DateTime   @default(now())
  ratings   Rating[]
  responses Response[]
}

model Rating {
  id String @id @default(uuid())

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id])

  giverId String
  giver   User   @relation("RatingGiver", fields: [giverId], references: [id])

  receiverId String
  receiver   User   @relation("RatingReceiver", fields: [receiverId], references: [id])

  pointValue Int @default(1)

  createdAt DateTime @default(now())
}

model Class {
  id          String       @id @default(uuid())
  level       Int
  name        String
  minPoints   Int
  forumId     String
  forum       Forum        @relation(fields: [forumId], references: [id])
  memberships Membership[]

  lessonAssignments ClassLessonAssignment[]
  chats             Chat[]
}

model ClassLessonAssignment {
  id       String @id @default(uuid(7))
  classId  String
  lessonId String
  order    Int // Order of this lesson within the specific class

  class  Class  @relation(fields: [classId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([classId, lessonId])
}

model Response {
  id        String @id @default(uuid(7))
  content   String
  chatId    String
  userId    String
  voteCount Int    @default(0)

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  chat   Chat @relation(fields: [chatId], references: [id])
  sender User @relation(fields: [userId], references: [id])

  votes Vote[]

  @@index(chatId)
}

model Vote {
  id         String   @id @default(uuid())
  userId     String
  responseId String
  createAt   DateTime @default(now())
  response   Response @relation(fields: [responseId], references: [id])

  @@unique([userId, responseId])
}
