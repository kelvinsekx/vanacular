// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum LearningObjective {
  CASUAL
  PROFESSIONAL
  TRAVEL
  EXAM
}

enum Role {
  USER
  ADMIN
}

enum ClassRole {
  STUDENT
  MODERATOR
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
}

model User {
  id                String            @id @default(uuid(7))
  email             String            @unique
  targetLanguageId  Int?
  targetLanguage    TargetLanguage?   @relation(fields: [targetLanguageId], references: [id])
  password          String
  bio               String?           @db.VarChar(160)
  avatarUrl         String?
  firstName         String?
  lastName          String?
  phone             String?           @unique
  learningObjective LearningObjective @default(CASUAL)
  nativeLanguage    String?
  dailyXpGoal       Int?
  role              Role              @default(USER)

  memberships  Membership[]
  ratingsGiven Rating[]     @relation("RatingGiver")
  ratingsRecd  Rating[]     @relation("RatingReceiver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Module {
  id         String         @id @default(uuid(7))
  languageId Int
  language   TargetLanguage @relation(fields: [languageId], references: [id])
  lessons    Lesson[]
}

model Lesson {
  id       String @id @default(uuid(7))
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id])
  title    String
  order    Int
  xpReward Int    @default(100)

  content LessonContent[]
}

model LessonContent {
  id       String      @id @default(uuid(7))
  lessonId String
  type     ContentType
  data     Json
  order    Int
  lesson   Lesson      @relation(fields: [lessonId], references: [id])
}

model TargetLanguage {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  identityExpression String @default("")
  users              User[]
  modules            Module[]
  forums             Forum[]
}

model Membership {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  classId String
  class   Class  @relation(fields: [classId], references: [id])

  role ClassRole @default(STUDENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, classId])
}

model Forum {
  id         String         @id @default(uuid())
  name       String
  languageId Int
  language   TargetLanguage @relation(fields: [languageId], references: [id])
  classes    Class[]
  posts      Post[]
}

model Post {
  id       String @id @default(uuid())
  content  String
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  forumId  String
  forum    Forum  @relation(fields: [forumId], references: [id])

  createdAt DateTime @default(now())
  ratings   Rating[]
}

model Rating {
  id String @id @default(uuid())

  postId String
  post   Post   @relation(fields: [postId], references: [id])

  giverId String
  giver   User   @relation("RatingGiver", fields: [giverId], references: [id])

  receiverId String
  receiver   User   @relation("RatingReceiver", fields: [receiverId], references: [id])

  pointValue Int @default(1)

  createdAt DateTime @default(now())
}

model Class {
  id          String       @id @default(uuid())
  level       Int
  name        String
  minPoints   Int
  forumId     String       @unique
  forum       Forum        @relation(fields: [forumId], references: [id])
  memberships Membership[]
}
